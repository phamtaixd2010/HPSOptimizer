<Window x:Class="HPSOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:HPSOptimizer.Views"
        Title="HPS Optimizer — Tối ưu Windows 11 &amp; Quản lý ổ đĩa"
        Icon="Assets/app.ico"
        Height="760" Width="1180" MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBg}">

    <DockPanel>
        <!-- Thanh tiêu đề thương hiệu -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Navy}" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo HP Steel nguyên bản. Chữ logo màu navy nên phải đặt trên nền trắng,
                     không tô lại màu logo. Chỉ scale theo Height, giữ nguyên tỷ lệ. -->
                <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="12,9" Margin="0,0,16,0">
                    <Image Source="Assets/logohps.png" Height="30" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="HPS Optimizer" FontSize="18" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Tối ưu hệ thống cho máy cấu hình thấp · Quản lý ổ đĩa"
                               FontSize="11.5" Foreground="#FFB9C7DD" />
                </StackPanel>

                <Border Grid.Column="2" x:Name="AdminBadge" CornerRadius="3" Padding="10,5"
                        Background="{StaticResource Orange}" VerticalAlignment="Center">
                    <TextBlock x:Name="AdminBadgeText" Text="ADMINISTRATOR" FontSize="10.5"
                               FontWeight="Bold" Foreground="{StaticResource Navy}" />
                </Border>
            </Grid>
        </Border>

        <!-- Thanh trạng thái -->
        <Border DockPanel.Dock="Bottom" Background="#FFEDF1F7" BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0" Padding="14,7">
            <TextBlock x:Name="StatusText" Style="{StaticResource Subtle}"
                       Text="Sẵn sàng. Mọi thay đổi hệ thống đều được ghi nhật ký và có thể hoàn tác." />
        </Border>

        <TabControl Margin="10" Background="Transparent" BorderThickness="0">
            <TabItem Header="Tổng quan">      <v:DashboardView /> </TabItem>
            <TabItem Header="Dọn rác">        <v:CleanView /> </TabItem>
            <TabItem Header="Khởi động">      <v:StartupView /> </TabItem>
            <TabItem Header="Dịch vụ">        <v:ServiceView /> </TabItem>
            <TabItem Header="Tinh chỉnh">     <v:TweakView /> </TabItem>
            <TabItem Header="Giám sát">       <v:MonitorView /> </TabItem>
            <TabItem Header="Ổ đĩa">          <v:DiskInfoView /> </TabItem>
            <TabItem Header="Dung lượng">     <v:DiskUsageView /> </TabItem>
            <TabItem Header="Bảo trì &amp; Phân vùng"> <v:DiskToolsView /> </TabItem>
            <TabItem Header="Nhật ký">        <v:LogView /> </TabItem>
        </TabControl>
    </DockPanel>
</Window>
