<UserControl x:Class="HPSOptimizer.Views.DiskToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="4,10,10,10">

        <TextBlock DockPanel.Dock="Bottom" x:Name="StatusLine" Style="{StaticResource Subtle}" Margin="0,8,0,0" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ===================== BẢO TRÌ ===================== -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Bảo trì ổ đĩa" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Subtle}" Margin="0,0,0,10">
                            App tự nhận diện loại ổ: SSD/NVMe sẽ chạy TRIM, HDD mới chống phân mảnh.
                            Không bao giờ defrag SSD. Quét lỗi chạy ở chế độ online, không cần khởi động lại.
                        </TextBlock>

                        <DataGrid x:Name="VolumeGrid" Height="150" IsReadOnly="True" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ổ" Width="60" Binding="{Binding Letter}" />
                                <DataGridTextColumn Header="Nhãn" Width="150" Binding="{Binding Label}" />
                                <DataGridTextColumn Header="Loại ổ vật lý" Width="130" Binding="{Binding MediaKind}" />
                                <DataGridTextColumn Header="Định dạng" Width="90" Binding="{Binding FileSystem}" />
                                <DataGridTextColumn Header="Trống / Tổng" Width="*" Binding="{Binding SpaceText}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="OptimizeBtn" Content="Tối ưu ổ đang chọn (TRIM / Defrag)" Click="Optimize_Click" />
                            <Button x:Name="ScanBtn" Content="Quét lỗi ổ đang chọn" Style="{StaticResource GhostButton}" Click="ScanVolume_Click" />
                            <Button Content="Tải lại" Style="{StaticResource GhostButton}" Click="Reload_Click" />
                            <ProgressBar x:Name="MaintProgress" Width="160" IsIndeterminate="True"
                                         Visibility="Collapsed" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ===================== PHÂN VÙNG ===================== -->
                <Border Style="{StaticResource Card}" BorderBrush="{StaticResource Danger}" BorderThickness="1.5">
                    <StackPanel>
                        <TextBlock Text="Phân vùng ổ đĩa" Style="{StaticResource H1}" Foreground="{StaticResource Danger}" />
                        <Border Background="#FFFDECEA" CornerRadius="4" Padding="12" Margin="0,4,0,12">
                            <TextBlock TextWrapping="Wrap" Foreground="#FF8E2A20">
                                <Run FontWeight="Bold" Text="Khu vực nguy hiểm." />
                                Xoá và format sẽ mất dữ liệu vĩnh viễn, không có thùng rác, không hoàn tác được.
                                Thu nhỏ phân vùng có thể thất bại giữa chừng nếu mất điện.
                                <LineBreak />
                                Phân vùng boot, system, recovery và EFI bị khoá — app sẽ từ chối mọi thao tác lên chúng.
                                Hãy sao lưu dữ liệu trước khi làm bất cứ điều gì ở đây.
                            </TextBlock>
                        </Border>

                        <DataGrid x:Name="PartGrid" Height="220" IsReadOnly="True" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Disk" Width="55" Binding="{Binding Disk}" />
                                <DataGridTextColumn Header="#" Width="40" Binding="{Binding Part}" />
                                <DataGridTextColumn Header="Ổ" Width="70" Binding="{Binding LetterText}" />
                                <DataGridTextColumn Header="Nhãn" Width="130" Binding="{Binding Label}" />
                                <DataGridTextColumn Header="Định dạng" Width="80" Binding="{Binding FileSystem}" />
                                <DataGridTextColumn Header="Kích thước" Width="100" Binding="{Binding SizeText}" />
                                <DataGridTextColumn Header="Trống" Width="100" Binding="{Binding FreeText}" />
                                <DataGridTextColumn Header="Loại" Width="110" Binding="{Binding Type}" />
                                <DataGridTextColumn Header="Co giãn được" Width="170" Binding="{Binding ResizeRangeText}" />
                                <DataGridTextColumn Header="" Width="*" Binding="{Binding ProtectedText}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Danger}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <WrapPanel>
                            <Button Content="Đổi kích thước…" Click="Resize_Click" />
                            <Button Content="Gán ký tự ổ…" Style="{StaticResource GhostButton}" Click="Letter_Click" />
                            <Button Content="Tạo phân vùng mới…" Style="{StaticResource GhostButton}" Click="Create_Click" />
                            <Button Content="Format…" Style="{StaticResource DangerButton}" Click="Format_Click" />
                            <Button Content="Xoá phân vùng…" Style="{StaticResource DangerButton}" Click="Delete_Click" />
                            <Button Content="Mở Disk Management" Style="{StaticResource GhostButton}" Click="OpenDiskMgmt_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
