<UserControl x:Class="HPSOptimizer.Views.DiskUsageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="4,10,10,10">

        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Phân tích dung lượng" Style="{StaticResource H1}" />
            <TextBlock Style="{StaticResource Subtle}" Margin="0,0,0,10"
                       Text="Tìm xem thư mục nào đang ăn hết ổ đĩa, và những file nào bị lưu trùng nhiều bản." />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Thư mục:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="PathBox" Width="380" Height="30" VerticalContentAlignment="Center" Padding="6,0" />
                <Button Content="Chọn…" Style="{StaticResource GhostButton}" Click="Browse_Click" Margin="8,0" />
                <TextBlock Text="Độ sâu:" VerticalAlignment="Center" Margin="8,0,6,0" />
                <ComboBox x:Name="DepthBox" Width="60" Height="30" SelectedIndex="1">
                    <ComboBoxItem Content="1" />
                    <ComboBoxItem Content="2" />
                    <ComboBoxItem Content="3" />
                    <ComboBoxItem Content="4" />
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="ScanBtn" Content="Quét cây thư mục" Click="Scan_Click" />
                <Button x:Name="DupBtn" Content="Tìm file trùng lặp (≥ 1 MB)" Style="{StaticResource GhostButton}" Click="Dup_Click" />
                <Button x:Name="CancelBtn" Content="Dừng" Style="{StaticResource DangerButton}" Click="Cancel_Click" IsEnabled="False" />
                <Button Content="Mở thư mục đang chọn" Style="{StaticResource GhostButton}" Click="OpenFolder_Click" />
            </StackPanel>

            <ProgressBar x:Name="Progress" IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,0,8" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" x:Name="StatusLine" Style="{StaticResource Subtle}" Margin="0,8,0,0" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Cây thư mục theo dung lượng" FontWeight="SemiBold"
                               Foreground="{StaticResource Navy}" Margin="0,0,0,8" />
                    <TreeView x:Name="Tree" BorderThickness="0" Background="Transparent">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Rectangle Height="9" Width="{Binding BarWidth}" Fill="{StaticResource Orange}"
                                               RadiusX="2" RadiusY="2" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding Header}" VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="File trùng lặp" FontWeight="SemiBold"
                               Foreground="{StaticResource Navy}" Margin="0,0,0,8" />
                    <TextBlock DockPanel.Dock="Bottom" x:Name="DupSummary" Style="{StaticResource Subtle}" Margin="0,8,0,0" />
                    <ListBox x:Name="DupList" BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,10">
                                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding Files}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Style="{StaticResource Subtle}"
                                                           TextWrapping="Wrap" Margin="10,1,0,0" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
