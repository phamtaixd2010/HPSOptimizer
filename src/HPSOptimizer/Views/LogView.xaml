<UserControl x:Class="HPSOptimizer.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="4,10,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- Nhật ký hoàn tác -->
        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Nhật ký thay đổi &amp; hoàn tác" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Subtle}" Margin="0,0,0,10">
                    Mỗi thay đổi hệ thống đều lưu lại giá trị cũ. Chọn một dòng rồi bấm Hoàn tác để trả về nguyên trạng.
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Tải lại" Style="{StaticResource GhostButton}" Click="Reload_Click" />
                    <Button Content="Hoàn tác mục đang chọn" Click="Revert_Click" />
                    <Button Content="Hoàn tác TẤT CẢ" Style="{StaticResource DangerButton}" Click="RevertAll_Click" />
                    <Button Content="Mở thư mục log" Style="{StaticResource GhostButton}" Click="OpenLogs_Click" />
                    <Button Content="Xoá nhật ký" Style="{StaticResource GhostButton}" Click="Clear_Click" />
                </StackPanel>
            </StackPanel>

            <DataGrid x:Name="UndoGrid" ItemsSource="{Binding Entries}" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Thời điểm" Width="110" Binding="{Binding TimeText}" />
                    <DataGridTextColumn Header="Thay đổi" Width="*" Binding="{Binding Title}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap" />
                                <Setter Property="Margin" Value="0,4" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Giá trị cũ" Width="120" Binding="{Binding OldValue}" />
                    <DataGridTextColumn Header="Giá trị mới" Width="120" Binding="{Binding NewValue}" />
                    <DataGridTextColumn Header="Trạng thái" Width="110" Binding="{Binding StatusText}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Reverted}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Log phiên chạy -->
        <DockPanel Grid.Column="1">
            <TextBlock DockPanel.Dock="Top" Text="Hoạt động phiên này" Style="{StaticResource H1}" />
            <ListBox x:Name="LogList" ItemsSource="{Binding Logs}" BorderBrush="{StaticResource Border}"
                     BorderThickness="1" Background="White"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Width="330">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                <Setter Property="Foreground" Value="{StaticResource Danger}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="Warn">
                                                <Setter Property="Foreground" Value="#FF9A6700" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="Success">
                                                <Setter Property="Foreground" Value="{StaticResource Success}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
