<UserControl x:Class="HPSOptimizer.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="4,10,10,10">

        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Giám sát tài nguyên" Style="{StaticResource H1}" />

            <Grid Margin="0,8,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="CpuValue" Text="—" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Navy}" />
                        <ProgressBar x:Name="CpuBar" Maximum="100" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="RAM" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="RamValue" Text="—" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Navy}" />
                        <ProgressBar x:Name="RamBar" Maximum="100" Margin="0,6,0,0" />
                        <TextBlock x:Name="RamDetail" Style="{StaticResource Subtle}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Ổ đĩa (hoạt động)" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="DiskValue" Text="—" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Navy}" />
                        <ProgressBar x:Name="DiskBar" Maximum="100" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Nhiệt độ CPU" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="TempValue" Text="—" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Navy}" />
                        <TextBlock Style="{StaticResource Subtle}" Margin="0,6,0,0"
                                   Text="Nhiều mainboard không cung cấp cảm biến này cho Windows." />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource Card}" Height="150">
                <Grid ClipToBounds="True">
                    <TextBlock Text="CPU (60 giây gần nhất)" Style="{StaticResource Subtle}"
                               HorizontalAlignment="Left" VerticalAlignment="Top" />
                    <Canvas x:Name="ChartCanvas" Background="Transparent" SizeChanged="Chart_SizeChanged">
                        <Polyline x:Name="CpuLine" Stroke="{StaticResource Navy}" StrokeThickness="1.8" />
                        <Polyline x:Name="RamLine" Stroke="{StaticResource Orange}" StrokeThickness="1.8" />
                    </Canvas>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Rectangle Width="10" Height="10" Fill="{StaticResource Navy}" VerticalAlignment="Center" />
                        <TextBlock Text=" CPU   " Style="{StaticResource Subtle}" />
                        <Rectangle Width="10" Height="10" Fill="{StaticResource Orange}" VerticalAlignment="Center" />
                        <TextBlock Text=" RAM" Style="{StaticResource Subtle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Kết thúc tiến trình đang chọn" Style="{StaticResource DangerButton}" Click="Kill_Click" />
                <TextBlock Style="{StaticResource Subtle}" VerticalAlignment="Center"
                           Text="Sắp xếp theo RAM đang chiếm. Không kết thúc tiến trình hệ thống trừ khi bạn biết rõ nó là gì." />
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="ProcGrid" ItemsSource="{Binding Processes}" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Width="80" Binding="{Binding Pid}" />
                <DataGridTextColumn Header="Tiến trình" Width="*" Binding="{Binding Name}" />
                <DataGridTextColumn Header="CPU" Width="90" Binding="{Binding CpuText}" />
                <DataGridTextColumn Header="RAM" Width="120" Binding="{Binding MemoryText}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
