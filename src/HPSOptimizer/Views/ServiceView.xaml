<UserControl x:Class="HPSOptimizer.Views.ServiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="4,10,10,10">
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Dịch vụ Windows" Style="{StaticResource H1}" />
            <TextBlock Style="{StaticResource Subtle}" Margin="0,0,0,10">
                Chỉ liệt kê các dịch vụ đã được xác nhận là tắt hoặc chuyển Manual an toàn.
                Windows Update, Defender và mạng không nằm trong danh sách này và sẽ không bị đụng tới.
                App tạo điểm khôi phục trước khi thay đổi.
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Tải lại" Style="{StaticResource GhostButton}" Click="Reload_Click" />
                <Button Content="Chọn tất cả mục tác động Cao" Style="{StaticResource GhostButton}" Click="SelectHigh_Click" />
                <Button x:Name="ApplyBtn" Content="Áp dụng khuyến nghị cho mục đã chọn" Click="Apply_Click" />
                <Button Content="Mở services.msc" Style="{StaticResource GhostButton}" Click="OpenMsc_Click" />
            </StackPanel>
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" x:Name="StatusLine" Style="{StaticResource Subtle}" Margin="0,8,0,0" />

        <DataGrid x:Name="Grid" ItemsSource="{Binding Items}">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Width="40"
                        Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <DataGridTextColumn Header="Dịch vụ" Width="260" Binding="{Binding DisplayName}" IsReadOnly="True" />
                <DataGridTextColumn Header="Hiện tại" Width="100" Binding="{Binding StartMode}" IsReadOnly="True" />
                <DataGridTextColumn Header="Khuyến nghị" Width="110" Binding="{Binding Recommended}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="{StaticResource Navy}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Trạng thái" Width="100" Binding="{Binding Status}" IsReadOnly="True" />
                <DataGridTextColumn Header="Tác động" Width="90" Binding="{Binding Impact}" IsReadOnly="True" />
                <DataGridTextColumn Header="Giải thích" Width="*" Binding="{Binding Advice}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="Margin" Value="0,4" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
