<UserControl x:Class="HPSOptimizer.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="4,10,10,10">
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Ứng dụng khởi động cùng Windows" Style="{StaticResource H1}" />
            <TextBlock Style="{StaticResource Subtle}" Margin="0,0,0,10">
                Tắt bớt ở đây là cách rẻ nhất để máy yếu vào desktop nhanh hơn.
                App xoá mục registry (đã lưu bản sao) hoặc đổi tên shortcut thành .hpsdisabled — hoàn tác được 100% ở tab Nhật ký.
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Tải lại danh sách" Style="{StaticResource GhostButton}" Click="Reload_Click" />
                <Button Content="Tắt các mục đã chọn" Style="{StaticResource DangerButton}" Click="Disable_Click" />
                <Button Content="Mở Task Manager" Style="{StaticResource GhostButton}" Click="TaskMgr_Click" />
            </StackPanel>
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" x:Name="StatusLine" Style="{StaticResource Subtle}" Margin="0,8,0,0" />

        <DataGrid x:Name="Grid" ItemsSource="{Binding Items}">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Width="40"
                        Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <DataGridTextColumn Header="Tên" Width="220" Binding="{Binding Name}" IsReadOnly="True" />
                <!-- Path= viết rõ: {Binding Source} sẽ bị hiểu nhầm là thuộc tính Source của Binding -->
                <DataGridTextColumn Header="Nguồn" Width="130" Binding="{Binding Path=Source}" IsReadOnly="True" />
                <DataGridTextColumn Header="Vị trí" Width="300" Binding="{Binding Location}" IsReadOnly="True" />
                <DataGridTextColumn Header="Lệnh chạy" Width="*" Binding="{Binding Command}" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
