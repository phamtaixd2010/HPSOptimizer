<UserControl x:Class="HPSOptimizer.Views.TweakView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="4,10,10,10">
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Tinh chỉnh hiệu năng Windows" Style="{StaticResource H1}" />
            <TextBlock Style="{StaticResource Subtle}" Margin="0,0,0,10">
                Mục &quot;An toàn&quot; đảo ngược được hoàn toàn và không ảnh hưởng bảo mật.
                Mục &quot;Cân nhắc&quot; có đánh đổi — đọc kỹ cột giải thích trước khi bật.
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Kiểm tra lại trạng thái" Style="{StaticResource GhostButton}" Click="Refresh_Click" />
                <Button Content="Chọn hết mục An toàn" Style="{StaticResource GhostButton}" Click="SelectSafe_Click" />
                <Button x:Name="ApplyBtn" Content="Áp dụng mục đã chọn" Click="Apply_Click" />
                <Button x:Name="RevertBtn" Content="Hoàn tác mục đã chọn" Style="{StaticResource DangerButton}" Click="Revert_Click" />
            </StackPanel>
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" x:Name="StatusLine" Style="{StaticResource Subtle}" Margin="0,8,0,0" />

        <DataGrid x:Name="Grid" ItemsSource="{Binding Tweaks}">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Width="40"
                        Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <DataGridTextColumn Header="Tinh chỉnh" Width="300" Binding="{Binding Name}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="Margin" Value="0,4" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Trạng thái" Width="110" Binding="{Binding State}" IsReadOnly="True" />
                <DataGridTextColumn Header="Mức độ" Width="90" Binding="{Binding RiskText}" IsReadOnly="True" />
                <DataGridTextColumn Header="Giải thích" Width="*" Binding="{Binding Description}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="Margin" Value="0,4" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
